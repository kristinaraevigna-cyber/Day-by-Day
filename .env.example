# Day by Day — frontend environment variables
# Copy to `.env` for local dev, or set these in the Render service env.
# Both are exposed to the browser bundle (VITE_ prefix) — only use the
# Supabase *anon* key here, never the service-role key.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# NOT set here: edge-function secrets.
# OPENAI_API_KEY and ANTHROPIC_API_KEY are consumed by the Supabase edge
# functions (voice-session, coach, day-advisor) and live in the Supabase
# project's edge-function secrets — not in this file and not in the frontend.
# ---------------------------------------------------------------------------
